# Окружение
ENVIRONMENT=dev
LOG_LEVEL=INFO

# Приложение
APP_NAME=CyberTracker API
DEBUG=false

# Сервер (uvicorn)
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
RELOAD=false

# CORS: список origin через запятую
ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# JWT
JWT_SECRET_KEY=change-me-use-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Cookie
COOKIE_NAME=access_token
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# AI / QR
AI_MODEL_PATH=models/attendance_model.joblib
QR_TOKEN_TTL_SECONDS=30

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=cybertracker
POSTGRES_ECHO=false
